rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ─── Helpers ─────────────────────────────────────────────────────────────

    function isAuth() {
      return request.auth != null;
    }

    function uid() {
      return request.auth.uid;
    }

    // Resolves user record from DB
    function userDoc() {
      return get(/databases/$(database)/documents/users/$(uid())).data;
    }

    // Checks if user is a member of the connection (used for read access to support legacy docs)
    function isConnectionMember(connData) {
      return isAuth() && connData.memberIds.hasAny([uid()]);
    }
    
    // Checks if user is an active member
    function isConnectionActiveMember(connData) {
      return isAuth() && connData.activeMemberIds.hasAny([uid()]);
    }

    function getConnectionData(connectionId) {
      return get(/databases/$(database)/documents/connections/$(connectionId)).data;
    }

    // ─── Users Collection ────────────────────────────────────────────────────

    match /users/{userId} {
      // Anyone can read profiles (e.g. to check login uniqueness or display nickname)
      allow read: if true;
      // Only the user themselves can write their profile
      allow write: if isAuth() && uid() == userId;
    }

    // ─── Connections Collection ──────────────────────────────────────────────

    match /connections/{connectionId} {
      // Member of the connection can read details, or anyone can read if it's pending an invite
      allow read: if isConnectionMember(resource.data) || (isAuth() && resource.data.status == 'pending_invite');
      
      // Anyone logged in can create a connection
      allow create: if isAuth() 
        && request.resource.data.createdBy == uid()
        && request.resource.data.memberIds.hasAny([uid()]);
      
      // Shared connection update (joining by invite code) OR active member updating it:
      allow update: if isConnectionActiveMember(resource.data) || (isAuth()
        && resource.data.status == 'pending_invite'
        && request.resource.data.status == 'active'
        && request.resource.data.memberIds.size() == 2
        && resource.data.memberIds[0] == request.resource.data.memberIds[0]
        && request.resource.data.memberIds[1] == uid());

      // Deleting connections is allowed for personal mode by creator
      allow delete: if isConnectionActiveMember(resource.data) 
        && resource.data.mode == 'personal'
        && resource.data.createdBy == uid();

      // ─── Activities Subcollection ──────────────────────────────────────────

      match /activities/{activityId} {
        // Any member of the parent connection can read activities
        allow read: if isConnectionMember(getConnectionData(connectionId));

        // Member of the connection can create an activity log
        allow create: if isConnectionActiveMember(getConnectionData(connectionId))
          && request.resource.data.connectionId == connectionId
          && request.resource.data.userId == uid();
          
        allow update, delete: if false;
      }

      // ─── Transactions Subcollection ────────────────────────────────────────

      match /transactions/{transactionId} {
        // Any member of the parent connection can read transactions
        allow read: if isConnectionMember(getConnectionData(connectionId));

        // Create transaction rules:
        // Member of the connection can create. Validates amount, currency, status.
        allow create: if isConnectionActiveMember(getConnectionData(connectionId))
          && request.resource.data.connectionId == connectionId
          && request.resource.data.createdBy == uid()
          && request.resource.data.amount > 0
          && request.resource.data.payerId != request.resource.data.beneficiaryId
          && request.resource.data.currency == getConnectionData(connectionId).currency
          && (
            // Shared mode: must start as pending
            (getConnectionData(connectionId).mode == 'shared' && request.resource.data.status == 'pending')
            ||
            // Personal mode: starts as confirmed, confirmedBy is creator
            (getConnectionData(connectionId).mode == 'personal' 
             && request.resource.data.status == 'confirmed'
             && request.resource.data.confirmedBy == uid())
          );

        // Update rules:
        // Any active member of the connection can update transactions (for confirm, reject, soft delete, or restore).
        // The UI handles specific validations, and all changes are logged in activities.
        allow update: if isConnectionActiveMember(getConnectionData(connectionId));

        // Deleting transactions is not allowed in MVP
        allow delete: if false;
      }
    }
  }
}
